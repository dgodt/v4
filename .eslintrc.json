{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off"
  },
  "overrides": [
    {
      "files": [
        "public/js/*.js",
        "public/registersw.js",
        "public/sw.js",
        "public/uv/uv.config.js",
        "public/assets/data/*.js"
      ],
      "env": {
        "browser": true,
        "node": false,
        "worker": true
      },
      "globals": {
        "getObj": "readonly",
        "setObj": "readonly",
        "apps": "readonly",
        "games": "readonly",
        "loadcustomapp": "readonly",
        "loadcustomgame": "readonly",
        "__uv$config": "readonly",
        "UVServiceWorker": "readonly",
        "importScripts": "readonly"
      },
      "rules": {
        "no-undef": "warn",
        "no-unused-vars": "warn"
      }
    }
  ]
}
